{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "xlsx-song-agent-sandbox",
  "main": "src/worker.ts",
  "compatibility_date": "2026-06-25",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "./dist/client",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/api/*", "/public/*"]
  },
  "ai": {
    "binding": "AI"
  },
  "worker_loaders": [
    {
      "binding": "LOADER"
    }
  ],
  "vars": {
    // Use AI_GATEWAY_FALLBACKS for chains like "anthropic:claude-sonnet-4-6,workers-ai:@cf/moonshotai/kimi-k2.7-code,openai:gpt-5.5".
    "AI_GATEWAY_ID": "aigovhack",
    "AI_GATEWAY_PROVIDER": "anthropic",
    "AI_GATEWAY_MODEL": "claude-sonnet-4-6",
    "AI_GATEWAY_FALLBACKS": "anthropic:claude-sonnet-4-6,workers-ai:@cf/moonshotai/kimi-k2.7-code,openai:gpt-5.5",
    // Set ELEVENLABS_API_KEY as a secret. Optional: override these defaults for a different voice/model.
    "ELEVENLABS_VOICE_ID": "JBFqnCBsd6RMkjVDRZzb",
    "ELEVENLABS_MODEL_ID": "eleven_multilingual_v2",
    "ELEVENLABS_MUSIC_MODEL_ID": "music_v2",
    "ELEVENLABS_OUTPUT_FORMAT": "mp3_44100_128"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "xlsx-song-spreadsheets",
      "database_id": "4b7c41d5-0c34-4b81-9a05-b258eb84aa4a",
      "migrations_dir": "migrations"
    }
  ],
  "r2_buckets": [
    {
      "binding": "SPREADSHEETS",
      "bucket_name": "xlsx-song-spreadsheets"
    }
  ],
  "containers": [
    {
      "class_name": "Sandbox",
      "image": "./Dockerfile",
      "instance_type": "basic",
      "max_instances": 5
    }
  ],
  "workflows": [
    {
      "binding": "EXTRACTION_WORKFLOW",
      "class_name": "ExtractionWorkflow",
      "name": "xlsx-song-extraction-workflow"
    }
  ],
  "durable_objects": {
    "bindings": [
      {
        "class_name": "SheetsThink",
        "name": "SheetsThink"
      },
      {
        "class_name": "AgentThink",
        "name": "AgentThink"
      },
      {
        "class_name": "Sandbox",
        "name": "Sandbox"
      }
    ]
  },
  "migrations": [
    {
      "new_sqlite_classes": ["HackathonAgent", "Sandbox"],
      "tag": "v1"
    },
    {
      "new_sqlite_classes": ["SheetsThink", "AgentThink"],
      "tag": "v2"
    }
  ]
}
